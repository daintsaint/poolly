# ─────────────────────────────────────────────
# Poolly — environment variables
# Copy to .env.local for local dev.
# All vars marked REQUIRED must be set in Railway before deploying.
# ─────────────────────────────────────────────

# Solana RPC endpoint
# Devnet:   https://api.devnet.solana.com
# Mainnet:  https://mainnet.helius-rpc.com/?api-key=YOUR_KEY  (get one at helius.dev)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com   # REQUIRED

# Admin dashboard password (Railway var ADMIN_SECRET)
ADMIN_SECRET=changeme                                # REQUIRED

# Upstash Redis — display name persistence
# Create a free database at console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=                             # REQUIRED in production
UPSTASH_REDIS_REST_TOKEN=                           # REQUIRED in production

# AI features (optional — routes degrade gracefully without these)
GROQ_API_KEY=                                       # groq.com
OPENAI_API_KEY=                                     # platform.openai.com  (proof verification)
IMGBB_API_KEY=                                      # imgbb.com            (proof image upload)
